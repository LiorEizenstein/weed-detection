<?xml version="1.0" ?>
<robot name="so_101" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Arguments -->
  <xacro:arg name="sim_backend" default="gazebo"/>

  <!-- Includes -->
  <xacro:include filename="$(find so_arm_101_description)/urdf/materials.xacro"/>
  <xacro:include filename="$(find so_arm_101_description)/urdf/so_101.ros2_control.xacro"/>

  <!-- MuJoCo-specific URDF extension: tell MuJoCo where to find mesh files -->
  <mujoco>
    <compiler meshdir="$(find so_arm_101_description)/meshes/collision"/>
  </mujoco>

  <!-- ============================================================ -->
  <!-- World frame — fixes the robot base to the ground              -->
  <!-- ============================================================ -->

  <link name="world"/>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================ -->
  <!-- Links                                                         -->
  <!-- ============================================================ -->

  <link name="base_link">
    <inertial>
      <origin xyz="-7.395983749131527e-05 0.018688778123587116 0.031975817456183726" rpy="0 0 0"/>
      <mass value="0.2092095548721987"/>
      <inertia ixx="0.000199" iyy="0.000196" izz="0.000203" ixy="1e-06" iyz="-1e-05" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/visual/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/collision/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="link1_1">
    <inertial>
      <origin xyz="-6.74951590711253e-05 -0.030490405697529033 0.053766555610065915" rpy="0 0 0"/>
      <mass value="0.24184654503223657"/>
      <inertia ixx="0.000195" iyy="0.000199" izz="9.5e-05" ixy="1e-06" iyz="1.6e-05" ixz="-2e-06"/>
    </inertial>
    <visual>
      <origin xyz="9.9e-05 0.007243 -0.027983" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/visual/link1_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="9.9e-05 0.007243 -0.027983" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/collision/link1_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="link2_1">
    <inertial>
      <origin xyz="-0.018388577871412994 0.06261038358877268 0.0010120440807449838" rpy="0 0 0"/>
      <mass value="0.98611438366224"/>
      <inertia ixx="0.001336" iyy="0.000432" izz="0.001637" ixy="1.3e-05" iyz="-3.7e-05" ixz="-1e-06"/>
    </inertial>
    <visual>
      <origin xyz="-0.020792 0.038556 -0.11936" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/visual/link2_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.020792 0.038556 -0.11936" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/collision/link2_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="link3_1">
    <inertial>
      <origin xyz="-0.017751520535904237 -0.06544031690248904 -0.0001729613192295032" rpy="0 0 0"/>
      <mass value="0.9031154796125306"/>
      <inertia ixx="0.001194" iyy="0.000364" izz="0.00144" ixy="1.5e-05" iyz="1.4e-05" ixz="-2e-06"/>
    </inertial>
    <visual>
      <origin xyz="-0.022302 -0.073879 -0.148777" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/visual/link3_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.022302 -0.073879 -0.148777" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/collision/link3_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="link4_1">
    <inertial>
      <origin xyz="-0.014388616159181473 -0.028802697165152366 -0.00020561897946119734" rpy="0 0 0"/>
      <mass value="0.31773533805976817"/>
      <inertia ixx="0.000138" iyy="0.000153" izz="0.000239" ixy="2.5e-05" iyz="0.0" ixz="-1e-06"/>
    </inertial>
    <visual>
      <origin xyz="-0.024382 0.060582 -0.152897" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/visual/link4_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.024382 0.060582 -0.152897" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/collision/link4_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="link5_1">
    <inertial>
      <origin xyz="-0.0005839285183169068 -0.04153912948671028 0.01505583353882603" rpy="0 0 0"/>
      <mass value="0.5561721109318601"/>
      <inertia ixx="0.000579" iyy="0.000983" izz="0.000737" ixy="1e-06" iyz="-8.4e-05" ixz="-5e-06"/>
    </inertial>
    <visual>
      <origin xyz="-0.007062 0.120627 -0.152066" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/visual/link5_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.007062 0.120627 -0.152066" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/collision/link5_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="clamp_1">
    <inertial>
      <origin xyz="0.0601695113719365 0.14480677890200364 0.1844826866723634" rpy="0 0 0"/>
      <mass value="0.15381179772652928"/>
      <inertia ixx="8.6e-05" iyy="4.1e-05" izz="7.3e-05" ixy="-1e-06" iyz="4e-06" ixz="-2e-06"/>
    </inertial>
    <visual>
      <origin xyz="0.045072 0.340704 0.033971" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/visual/clamp_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0.045072 0.340704 0.033971" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/collision/clamp_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="clamp_2">
    <inertial>
      <origin xyz="-0.0800042161303889 0.1470101120878245 0.18506826370370444" rpy="0 0 0"/>
      <mass value="0.15381179772652928"/>
      <inertia ixx="8.6e-05" iyy="4.1e-05" izz="7.3e-05" ixy="1e-06" iyz="-4e-06" ixz="-2e-06"/>
    </inertial>
    <visual>
      <origin xyz="-0.07989 0.342905 0.031809" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/visual/clamp_2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.07989 0.342905 0.031809" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://so_arm_101_description/meshes/collision/clamp_2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- Joints                                                        -->
  <!-- ============================================================ -->

  <!-- Joint 1: Base rotation (Yaw) -->
  <joint name="base_link_to_link1" type="revolute">
    <origin xyz="-9.9e-05 -0.007243 0.027983" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link1_1"/>
    <axis xyz="-0.0 -0.008727 0.999962"/>
    <limit lower="-2.094395" upper="2.094395" effort="10.0" velocity="5.236"/>
    <dynamics damping="0.1" friction="0.05"/>
    <safety_controller soft_lower_limit="-2.044" soft_upper_limit="2.044" k_position="100" k_velocity="10"/>
  </joint>

  <!-- Joint 2: Shoulder pitch — STS3215 servo -->
  <joint name="link1_to_link2" type="revolute">
    <origin xyz="0.020891 -0.031313 0.091377" rpy="0 0 0"/>
    <parent link="link1_1"/>
    <child link="link2_1"/>
    <axis xyz="-0.999962 -0.008726 -7.6e-05"/>
    <limit lower="-3.228859" upper="0.174533" effort="10.0" velocity="5.236"/>
    <dynamics damping="0.1" friction="0.05"/>
    <safety_controller soft_lower_limit="-3.179" soft_upper_limit="0.125" k_position="100" k_velocity="10"/>
  </joint>

  <!-- Joint 3: Elbow — STS3215 servo -->
  <joint name="link2_to_link3" type="revolute">
    <origin xyz="0.00151 0.112435 0.029417" rpy="0 0 0"/>
    <parent link="link2_1"/>
    <child link="link3_1"/>
    <axis xyz="-0.999924 -0.00865 -0.008802"/>
    <limit lower="0.0" upper="3.316126" effort="10.0" velocity="5.236"/>
    <dynamics damping="0.1" friction="0.05"/>
    <safety_controller soft_lower_limit="0.05" soft_upper_limit="3.266" k_position="100" k_velocity="10"/>
  </joint>

  <!-- Joint 4: Wrist pitch — STS3215 servo -->
  <joint name="link3_to_link4" type="revolute">
    <origin xyz="0.00208 -0.134461 0.00412" rpy="0 0 0"/>
    <parent link="link3_1"/>
    <child link="link4_1"/>
    <axis xyz="-0.999848 0.000153 -0.017451"/>
    <limit lower="-1.658063" upper="1.658063" effort="10.0" velocity="5.236"/>
    <dynamics damping="0.1" friction="0.05"/>
    <safety_controller soft_lower_limit="-1.608" soft_upper_limit="1.608" k_position="100" k_velocity="10"/>
  </joint>

  <!-- Joint 5: Wrist roll — STS3215 servo -->
  <joint name="link4_to_link5" type="revolute">
    <origin xyz="-0.01732 -0.060045 -0.000831" rpy="0 0 0"/>
    <parent link="link4_1"/>
    <child link="link5_1"/>
    <axis xyz="-1e-06 0.999961 0.008803"/>
    <limit lower="-4.276057" upper="1.570796" effort="10.0" velocity="5.236"/>
    <dynamics damping="0.1" friction="0.05"/>
    <safety_controller soft_lower_limit="-4.226" soft_upper_limit="1.521" k_position="100" k_velocity="10"/>
  </joint>

  <!-- Gripper clamps — fixed in simulation (not used for scanning) -->
  <joint name="right_clamp" type="fixed">
    <origin xyz="-0.052134 -0.220077 -0.186037" rpy="0 0 0"/>
    <parent link="link5_1"/>
    <child link="clamp_1"/>
  </joint>

  <joint name="left_clamp" type="fixed">
    <origin xyz="0.072828 -0.222278 -0.183875" rpy="0 0 0"/>
    <parent link="link5_1"/>
    <child link="clamp_2"/>
  </joint>

  <!-- ============================================================ -->
  <!-- D435 colour camera mounted on link5_1 (wrist/end-effector)  -->
  <!-- ============================================================ -->

  <link name="camera_link">
    <visual>
      <geometry><box size="0.025 0.090 0.025"/></geometry>
      <material name="silver"/>
    </visual>
  </link>

  <link name="camera_color_optical_frame"/>

  <joint name="link5_to_camera" type="fixed">
    <parent link="link5_1"/>
    <child  link="camera_link"/>
    <!-- perpendicular to ground: Rx(-0.5) cancels the Rx(+0.5) that
         joints [-1.5,1.5,-0.5,0] impose on link5_1 relative to world -->
    <origin xyz="0.0 0.0 0.08" rpy="-0.5 0 0"/>
  </joint>

  <joint name="camera_to_optical" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_color_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- Gazebo camera sensor — topic bridged to ROS 2 by ros_gz_bridge -->
  <gazebo reference="camera_link">
    <sensor name="d435_color" type="camera">
      <update_rate>10</update_rate>
      <topic>/camera/image_raw</topic>
      <camera name="color">
        <horizontal_fov>1.2043728</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>RGB_INT8</format>
        </image>
        <clip><near>0.01</near><far>10.0</far></clip>
      </camera>
    </sensor>
  </gazebo>

</robot>
